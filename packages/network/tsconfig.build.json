{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@echojs-ecosystem/oxc-config/tsconfig",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "**/*.integration.test.ts",
    "**/*.test-d.ts",
    "**/*.spec.ts",
    "bench/**"
  ]
}
