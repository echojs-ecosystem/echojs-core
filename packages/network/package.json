{
  "name": "@echojs-ecosystem/network",
  "version": "0.6.0",
  "description": "EchoJS network toolkit — tree-shakeable HTTP, WebSocket, GraphQL, and mock subpath imports",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./ws": {
      "types": "./dist/ws.d.ts",
      "import": "./dist/ws.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.js"
    },
    "./graphql": {
      "types": "./dist/graphql.d.ts",
      "import": "./dist/graphql.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.typing.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.typing.json --noEmit",
    "test:types": "tsc -p tsconfig.typing.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench"
  },
  "devDependencies": {
    "@echojs-ecosystem/oxc-config": "workspace:*",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/echojs-ecosystem/echojs-core.git",
    "directory": "packages/network"
  }
}
