{
  "extends": "../.configs/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "outDir": "./dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@echojs/reactivity": ["../reactivity/src/index.ts"]
    },
    "rootDir": ".."
  },
  "include": ["src/**/*", "vitest.config.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.test-d.ts",
    "**/*.spec.ts",
    "src/vitest.setup.ts"
  ]
}
