{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@echojs/oxc-config/tsconfig",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.test-d.ts", "**/*.spec.ts"]
}

