{
  "name": "@echojs/architect",
  "version": "0.0.0",
  "private": true,
  "description": "Architecture linter for EchoJS projects — core engine and CLI",
  "files": ["dist"],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "echo-architect": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "c12": "^1.11.2",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "citty": "^0.1.6",
    "figures": "^6.1.0",
    "globby": "^14.0.2",
    "immer": "^10.1.1",
    "is-glob": "^4.0.3",
    "minimatch": "^10.0.1",
    "precinct": "^12.1.2",
    "prexit": "^2.3.0",
    "rxjs": "^7.8.1",
    "terminal-link": "^3.0.0",
    "tsconfck": "^3.1.3",
    "zod": "^3.23.8",
    "zod-validation-error": "^3.3.1"
  },
  "peerDependencies": {
    "typescript": ">=5"
  },
  "devDependencies": {
    "@echojs/oxc-config": "workspace:*",
    "@types/is-glob": "^4.0.4",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  }
}
