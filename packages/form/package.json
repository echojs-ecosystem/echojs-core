{
  "name": "@echojs/form",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@echojs-ecosystem/reactivity": "workspace:*",
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@echojs-ecosystem/oxc-config": "workspace:*",
    "typescript": "5.9.2",
    "vitest": "^4.1.4",
    "zod": "^3.25.28"
  }
}

