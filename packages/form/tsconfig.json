{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../.configs/tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@echojs/reactivity": ["../reactivity/src/index.ts"],
      "@echojs/persist": ["../persist/src/index.ts"]
    },
    "rootDir": ".."
  },
  "include": ["src/**/*", "vitest.config.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.test-d.ts",
    "**/*.spec.ts"
  ]
}
