{
  "name": "@echojs-ecosystem/jsx-runtime",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "bun run --hot example/server.ts",
    "example": "bun run example/server.ts",
    "example:build": "bun build example/*.tsx --outdir example/dist --target browser --jsx automatic --jsx-import-source @echojs-ecosystem/jsx-runtime"
  },
  "dependencies": {
    "@echojs-ecosystem/reactivity": "workspace:*"
  },
  "devDependencies": {
    "@echojs-ecosystem/oxc-config": "workspace:*",
    "oxlint": "^1.60.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  }
}
