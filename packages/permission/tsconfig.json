{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../.configs/tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@echojs-ecosystem/reactivity": ["../reactivity/src/index.ts"]
    },
    "rootDir": ".."
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.test-d.ts",
    "**/*.spec.ts",
    "tests/**/*"
  ]
}
