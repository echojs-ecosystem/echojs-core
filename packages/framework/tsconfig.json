      "@echojs-ecosystem/persist": ["../persist/src/index.ts"],
      "@echojs-ecosystem/store": ["../store/src/index.ts"],
      "@echojs-ecosystem/ui": ["../ui/src/index.ts"],
      "@echojs-ecosystem/ui/button": ["../ui/src/components/button/index.ts"],
