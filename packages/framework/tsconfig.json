      "@echojs-ecosystem/ui/provider": ["../ui/src/providers/index.ts"],
      "@echojs-ecosystem/ui/theme": ["../ui/src/theme/index.ts"],
      "@echojs-ecosystem/ui/core": ["../ui/src/core/index.ts"],
      "@echojs-ecosystem/ui/utils": ["../ui/src/utils/index.ts"],
      "@echojs-ecosystem/ui/primitives": ["../ui/src/primitives/index.ts"],
