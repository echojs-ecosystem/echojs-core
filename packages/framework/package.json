{
  "name": "@echojs/framework",
  "version": "0.0.0",
  "private": true,
  "files": ["dist"],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./reactivity": {
      "types": "./dist/reactivity.d.ts",
      "default": "./dist/reactivity.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "default": "./dist/router.js"
    },
    "./router/hyperdom": {
      "types": "./dist/router-hyperdom.d.ts",
      "default": "./dist/router-hyperdom.js"
    },
    "./form": {
      "types": "./dist/form.d.ts",
      "default": "./dist/form.js"
    },
    "./persist": {
      "types": "./dist/persist.d.ts",
      "default": "./dist/persist.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "default": "./dist/store.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    },
    "./hyperdom": {
      "types": "./dist/hyperdom.d.ts",
      "default": "./dist/hyperdom.js"
    },
    "./url-state": {
      "types": "./dist/url-state.d.ts",
      "default": "./dist/url-state.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt ."
  },
  "dependencies": {
    "@echojs/core": "workspace:*",
    "@echojs/reactivity": "workspace:*",
    "@echojs/router": "workspace:*",
    "@echojs/hyperdom": "workspace:*",
    "@echojs/form": "workspace:*",
    "@echojs/persist": "workspace:*",
    "@echojs/store": "workspace:*",
    "@echojs/ui": "workspace:*",
    "@echojs/url-state": "workspace:*"
  },
  "devDependencies": {
    "@echojs/oxc-config": "workspace:*",
    "oxlint": "^1.60.0",
    "typescript": "5.9.2"
  }
}
