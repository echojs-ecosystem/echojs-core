{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../.configs/tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@echojs-ecosystem/hyperdom": ["../hyperdom/src/index.ts"],
      "@echojs-ecosystem/reactivity": ["../reactivity/src/index.ts"]
    },
    "rootDir": ".."
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "storybook-static",
    "src/**/*.test.ts",
    "src/**/*.test-d.ts",
    "src/**/*.stories.ts",
    "src/storybook"
  ]
}
