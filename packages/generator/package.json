{
  "name": "@echojs-ecosystem/generator",
  "version": "0.9.0",
  "description": "EchoJS code generation toolkit — extensible OpenAPI generators built on Kubb",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "generate:example": "bun run http/scripts/generate-example.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@kubb/ast": "^4.38.0",
    "@kubb/core": "^4.38.0",
    "@kubb/oas": "^4.38.0",
    "@kubb/plugin-msw": "^4.38.0",
    "@kubb/plugin-oas": "^4.38.0",
    "@kubb/plugin-ts": "^4.38.0",
    "@kubb/plugin-zod": "^4.38.0",
    "handlebars": "^4.7.9",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "typescript": ">=5"
  },
  "devDependencies": {
    "@echojs-ecosystem/network": "workspace:*",
    "@echojs-ecosystem/oxc-config": "workspace:*",
    "@types/handlebars": "^4.1.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/echojs-ecosystem/echojs-core.git",
    "directory": "packages/generator"
  }
}
