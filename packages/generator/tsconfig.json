{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../.configs/tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "types": ["bun-types", "node"],
    "baseUrl": ".",
    "rootDir": ".."
  },
  "include": ["core/src/**/*", "http/src/**/*", "http/.tmp/generated-api/**/*", "http/echo-http.generator.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
