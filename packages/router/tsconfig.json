{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../.configs/tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@echojs-ecosystem/reactivity": ["../reactivity/src/index.ts"],
      "@echojs-ecosystem/hyperdom": ["../hyperdom/src/index.ts"],
      "@echojs-ecosystem/url-state": ["../url-state/src/index.ts"]
    },
    "rootDir": ".."
  },
  "include": ["src/**/*", "vitest.config.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.test-d.ts",
    "**/*.spec.ts",
    "src/vitest.setup.ts",
    "src/test-utils.ts"
  ]
}
