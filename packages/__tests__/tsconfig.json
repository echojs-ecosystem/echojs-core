{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../.configs/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals", "node"]
  },
  "include": ["packages/**/*.ts", "shared/**/*.ts", "stacks/**/*.ts"],
  "exclude": [
    "node_modules",
    "vitest.config.ts",
    "playwright.config.ts",
    "packages/**/e2e/**"
  ]
}
