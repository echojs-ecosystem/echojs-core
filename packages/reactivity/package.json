{
  "name": "@echojs-ecosystem/reactivity",
  "version": "0.3.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.typing.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.typing.json --noEmit",
    "test:types": "tsc -p tsconfig.typing.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest ui"
  },
  "dependencies": {
    "alien-signals": "^3.1.2"
  },
  "devDependencies": {
    "@echojs-ecosystem/oxc-config": "workspace:*",
    "oxlint": "^1.60.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/echojs-ecosystem/echojs-core.git",
    "directory": "packages/reactivity"
  }
}
