{
  "name": "echojs-core",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/.configs"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:http": "turbo run build --filter=@echojs/network-http",
    "dev": "turbo run dev",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint:and:format": "bun run oxlint && bun run oxfmt",
    "changeset": "changeset",
    "version:all": "changeset version",
    "publish:all": "changeset publish",
    "clean": "turbo run clean",
    "graph": "npx nx graph ",
    "release": "changeset publish",
    "release:canary": "changeset publish --no-git-tag",
    "start": "turbo run start --filter=./packages/*",
    "typecheck": "turbo run typecheck --continue --filter='./packages/*'",
    "upgrade": "npx taze -r -w --exclude pnpm",
    "version": "changeset version",
    "version:canary": "changeset version --snapshot canary"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@echojs-ecosystem/oxc-config": "workspace:*",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6"
}
