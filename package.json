{
  "name": "echojs-core",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/workspace/*",
    "packages/*",
    "packages/.configs",
    "tools/bench"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "dev": "turbo run dev",
    "storybook:build": "turbo run storybook:build --filter=@echojs-ecosystem/ui",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage && node tools/scripts/coverage-report.mjs",
    "size": "node tools/scripts/size-report.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint:and:format": "bun run oxlint && bun run oxfmt",
    "changeset": "changeset",
    "sync-versions": "node tools/scripts/sync-package-versions.mjs",
    "version:all": "changeset version && node tools/scripts/sync-package-versions.mjs",
    "publish:all": "bun run release",
    "clean": "turbo run clean",
    "graph": "npx nx graph ",
    "release": "bun run build:packages && bun run release:verify && node tools/scripts/publish-all.mjs",
    "release:canary": "bun run build:packages && bun run release:verify && node tools/scripts/publish-all.mjs --tag canary --no-git-tag",
    "release:verify": "node tools/scripts/verify-publish-pack.mjs",
    "start": "turbo run start --filter=./packages/*",
    "typecheck": "turbo run typecheck --continue --filter='./packages/*'",
    "upgrade": "npx taze -r -w --exclude pnpm",
    "version": "changeset version && node tools/scripts/sync-package-versions.mjs && bun update",
    "version:canary": "changeset version --snapshot canary && node tools/scripts/sync-package-versions.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@echojs-ecosystem/oxc-config": "workspace:*",
    "@types/node": "^24.13.1",
    "@vitest/coverage-v8": "^4.1.8",
    "bun-types": "^1.3.14",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.68.0",
    "stylelint-standard": "^1.2.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6"
}
