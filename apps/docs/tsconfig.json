{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@pages/*": ["src/pages/*"],
      "@entities/*": ["src/entities/*"],
      "@widgets/*": ["src/widgets/*"],
      "@core/*": ["src/core/*"],
      "@content/*": ["src/content/*"],
      "@echojs-ecosystem/framework": ["../../packages/framework/src/index.ts"],
      "@echojs-ecosystem/framework/app": ["../../packages/framework/src/app/index.ts"],
      "@echojs-ecosystem/framework/router/hyperdom": ["../../packages/framework/src/router-hyperdom.ts"],
      "@echojs-ecosystem/framework/hyperdom/lifecycle/mount": ["../../packages/framework/src/hyperdom-lifecycle-mount.ts"],
      "@echojs-ecosystem/framework/ui/*": ["../../packages/framework/src/ui/*"],
      "@echojs-ecosystem/framework/*": ["../../packages/framework/src/*"]
    }
  },
  "include": ["src", "src/vite-env.d.ts"]
}
