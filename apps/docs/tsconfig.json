{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@pages/*": ["src/pages/*"],
      "@entities/*": ["src/entities/*"],
      "@widgets/*": ["src/widgets/*"],
      "@core/*": ["src/core/*"],
      "@content/*": ["src/content/*"],
      "@echojs-ecosystem/reactivity": ["../../packages/reactivity/src/index.ts"],
      "@echojs-ecosystem/hyperdom": ["../../packages/hyperdom/src/index.ts"],
      "@echojs-ecosystem/hyperdom/*": ["../../packages/hyperdom/src/*"],
      "@echojs-ecosystem/router": ["../../packages/router/src/index.ts"],
      "@echojs-ecosystem/router/hyperdom": ["../../packages/router/src/hyperdom/index.ts"],
      "@echojs-ecosystem/store": ["../../packages/store/src/index.ts"],
      "@echojs-ecosystem/persist": ["../../packages/persist/src/index.ts"],
      "@echojs-ecosystem/url-state": ["../../packages/url-state/src/index.ts"],
      "@echojs-ecosystem/query": ["../../packages/query/src/index.ts"],
      "@echojs-ecosystem/i18n": ["../../packages/i18n/src/index.ts"],
      "@echojs-ecosystem/framework": ["../../packages/framework/src/index.ts"],
      "@echojs-ecosystem/framework/app": ["../../packages/framework/src/app/index.ts"],
      "@echojs-ecosystem/framework/query": ["../../packages/framework/src/query.ts"],
      "@echojs-ecosystem/framework/i18n": ["../../packages/framework/src/i18n.ts"],
      "@echojs-ecosystem/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": ["src", "src/vite-env.d.ts"]
}
