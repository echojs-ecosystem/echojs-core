{
  "name": "@echojs-ecosystem/docs",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "imports:normalize": "node scripts/normalize-imports.mjs",
    "architect": "echo-architect lint",
    "architect:watch": "echo-architect lint --watch",
    "architect:fix": "echo-architect lint --fix"
  },
  "dependencies": {
    "@echojs-ecosystem/framework": "^0.9.0",
    "@echojs-ecosystem/utils": "workspace:*",
    "shiki": "^3.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^1.0.0"
  },
  "devDependencies": {
    "@echojs-ecosystem/architect": "^0.9.0",
    "@tailwindcss/vite": "^4.1.8",
    "tailwindcss": "^4.1.8",
    "typescript": "5.9.2",
    "vite": "^6.0.0"
  }
}
