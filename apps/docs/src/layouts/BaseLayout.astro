---
import "../styles/global.css";

export type Props = {
  title: string;
  description?: string;
};

const { title, description } = Astro.props;
const pageTitle = `${title} · EchoJS`;
const pageDescription =
  description ??
  "Документация по пакетам EchoJS: reactivity, core, hyperdom, ui и другие.";

const githubUrl = "https://github.com/echojs-ecosystem/echojs-core";
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (() => {
        const storageKey = "theme";
        const stored = typeof localStorage !== "undefined" ? localStorage.getItem(storageKey) : null;
        const system = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        const theme = stored === "light" || stored === "dark" ? stored : system;
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
        window.__echoTheme = {
          get: () => document.documentElement.dataset.theme || theme,
          set: (next) => {
            document.documentElement.dataset.theme = next;
            document.documentElement.style.colorScheme = next;
            try { localStorage.setItem(storageKey, next); } catch {}
          },
          toggle: () => {
            const cur = document.documentElement.dataset.theme === "light" ? "light" : "dark";
            const next = cur === "dark" ? "light" : "dark";
            window.__echoTheme.set(next);
          },
        };
      })();
    </script>
    <style>
      /* avoid FOUC: tiny baseline */
      body{background:#070a12}
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="container topbarInner">
        <a class="brand" href="/">
          <span class="brandDot" aria-hidden="true"></span>
          <span>EchoJS</span>
          <span class="badge mono">core</span>
        </a>

        <div class="topbarRight">
          <nav class="nav" aria-label="Навигация">
            <a href="/getting-started">Старт</a>
            <a href="/packages">Пакеты</a>
            <a href="/guides/philosophy">Философия</a>
          </nav>

          <div class="actions" aria-label="Действия">
            <button class="searchBtn" type="button" aria-label="Поиск (скоро)">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M21 21l-4.35-4.35"></path>
              </svg>
              <span class="searchLabel">Поиск…</span>
              <span class="kbd" aria-hidden="true">K</span>
            </button>

            <button id="themeToggle" class="iconBtn" type="button" aria-label="Переключить тему">
              <svg class="icon iconSun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2"></path><path d="M12 20v2"></path>
                <path d="M4.93 4.93l1.41 1.41"></path><path d="M17.66 17.66l1.41 1.41"></path>
                <path d="M2 12h2"></path><path d="M20 12h2"></path>
                <path d="M4.93 19.07l1.41-1.41"></path><path d="M17.66 6.34l1.41-1.41"></path>
              </svg>
              <svg class="icon iconMoon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12.8A8.5 8.5 0 0 1 11.2 3a7 7 0 1 0 9.8 9.8Z"></path>
              </svg>
            </button>

            <a class="iconBtn" href={githubUrl} rel="noreferrer" aria-label="Открыть GitHub репозиторий">
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="currentColor" d="M12 2a10 10 0 0 0-3.16 19.49c.5.1.68-.22.68-.48v-1.7c-2.77.6-3.36-1.17-3.36-1.17-.45-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.54 2.35 1.1 2.92.84.09-.66.35-1.1.63-1.36-2.21-.25-4.53-1.11-4.53-4.95 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.6 9.6 0 0 1 12 6.8c.85 0 1.71.11 2.51.33 1.9-1.29 2.74-1.02 2.74-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.85-2.33 4.7-4.55 4.95.36.31.68.92.68 1.85v2.73c0 .27.18.59.69.48A10 10 0 0 0 12 2Z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div>
          <span class="mono">EchoJS</span> — документация в разработке.  
          Источник: монорепо `echojs-core`.
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const btn = document.getElementById("themeToggle");
        if (!btn || !window.__echoTheme) return;
        btn.addEventListener("click", () => window.__echoTheme.toggle());
        document.addEventListener("astro:after-swap", () => {
          const t = window.__echoTheme.get();
          document.documentElement.dataset.theme = t;
          document.documentElement.style.colorScheme = t;
        });
      })();
    </script>
  </body>
</html>

