---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="@echojs/persist" description="Persist слой для EchoJS (расширение стора).">
  <section class="section">
    <div class="container">
      <p class="kicker">Пакет</p>

      <div class="card">
        <div class="cardPad">
          <p class="cardTitle"><span class="mono">@echojs/persist</span></p>
          <p class="cardText">
            Пакет для persistence-расширений (например, хранение в storage) поверх <span class="mono">@echojs/store</span>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

