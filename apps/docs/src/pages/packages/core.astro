---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="@echojs/core" description="Core-слой EchoJS: базовые примитивы и foundation для пакетов экосистемы.">
  <section class="section">
    <div class="container">
      <p class="kicker">Пакет</p>

      <div class="card">
        <div class="cardPad">
          <p class="cardTitle"><span class="mono">@echojs/core</span></p>
          <p class="cardText">
            Базовый пакет экосистемы. Как правило, он собирает core-примитивы и связывает остальные пакеты
            (например, опирается на <span class="mono">@echojs/reactivity</span>).
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

