---
import BaseLayout from "../../layouts/BaseLayout.astro";

const packages = [
  { name: "@echojs/reactivity", href: "/packages/reactivity/", desc: "Строгая реактивность (signals/computed/effect/batch)." },
  { name: "@echojs/core", href: "/packages/core", desc: "Базовые примитивы и core-слой." },
  { name: "@echojs/hyperdom", href: "/packages/hyperdom", desc: "DOM-рендерер и DSL, поверх reactivity." },
  { name: "@echojs/ui", href: "/packages/ui", desc: "UI-компоненты и тема (Storybook)." },
  { name: "@echojs/router", href: "/packages/router", desc: "Router как plain objects + signals, URL ↔ состояние." },
  { name: "@echojs/query", href: "/packages/query", desc: "Query/cache/mutations, signal-native, TanStack-inspired." },
  { name: "@echojs/store", href: "/packages/store", desc: "Минимальный store layer поверх reactivity." },
  { name: "@echojs/persist", href: "/packages/persist", desc: "Persist слой (расширения к store)." },
  { name: "@echojs/i18n", href: "/packages/i18n", desc: "i18n для приложений EchoJS." },
  { name: "@echojs/url-state", href: "/packages/url-state", desc: "Синхронизация состояния с URL." },
  { name: "@echojs/form", href: "/packages/form", desc: "Формы и валидация (модельный слой)." },
  { name: "@echojs/framework", href: "/packages/framework", desc: "Интеграционные утилиты экосистемы." },
  { name: "@echojs/devtools-core", href: "/packages/devtools-core", desc: "Основы devtools (core)." },
  { name: "@echojs/bench", href: "/packages/bench", desc: "Бенчмарки/вспомогательные штуки." },
];
---

<BaseLayout title="Пакеты" description="Каталог пакетов EchoJS и быстрые ссылки на документацию.">
  <section class="section">
    <div class="container">
      <p class="kicker">Каталог пакетов</p>
      <div class="grid">
        {packages.map((p) => (
          <a class="card col4" href={p.href}>
            <div class="cardPad">
              <p class="cardTitle">
                <span class="mono">{p.name}</span>
              </p>
              <p class="cardText">{p.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

