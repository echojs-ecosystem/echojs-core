---
import BaseLayout from "../layouts/BaseLayout.astro";

const packages = [
  {
    name: "@echojs/reactivity",
    href: "/packages/reactivity/",
    desc: "Строгая реактивность с объектным API (writable/readonly), поверх alien-signals.",
    tags: ["signals", "computed", "effect", "batch"],
    size: { min: "6.44 kB", gzip: "2.41 kB", brotli: "2.23 kB" },
    pros: [
      "Строгое разделение writable/readonly",
      "Чтение без случайных мутаций через DeepReadonly",
      "Dev deep-freeze для быстрых ошибок",
    ],
  },
  {
    name: "@echojs/core",
    href: "/packages/core",
    desc: "Core-утилиты и базовые примитивы для экосистемы EchoJS.",
    tags: ["foundation", "interop"],
    size: { min: "15.58 kB", gzip: "5.57 kB", brotli: "5.04 kB" },
    pros: ["Базовый foundation пакет экосистемы", "Минимальный surface, меньше магии"],
  },
  {
    name: "@echojs/hyperdom",
    href: "/packages/hyperdom",
    desc: "DOM-рендерер и DSL, построенный на реактивности EchoJS.",
    tags: ["dom", "dsl", "events"],
    size: { min: "10.25 kB", gzip: "4.02 kB", brotli: "3.67 kB" },
    pros: ["DSL для DOM", "Предсказуемые события/props", "Опора на signals"],
  },
  {
    name: "@echojs/ui",
    href: "/packages/ui",
    desc: "UI-компоненты и темы, поверх hyperdom (Storybook в монорепо).",
    tags: ["components", "theme", "a11y"],
    size: { min: "31.12 kB", gzip: "10.15 kB", brotli: "9.26 kB" },
    pros: ["Компоненты + тема + provider", "Storybook для живых примеров", "a11y-проверки"],
  },
  {
    name: "@echojs/router",
    href: "/packages/router",
    desc: "Программируемый router: маршруты — plain objects с сигналами, URL ↔ состояние.",
    tags: ["routing", "guards", "lazy"],
    size: { min: "23.93 kB", gzip: "8.23 kB", brotli: "7.50 kB" },
    pros: ["Routes как plain objects с signals", "Guards/redirect/operators", "Lazy route views"],
  },
  {
    name: "@echojs/query",
    href: "/packages/query",
    desc: "Signal-native query/cache/mutation слой, вдохновлён TanStack Query (query-core).",
    tags: ["cache", "fetch", "abort"],
    size: { min: "не в отчёте", gzip: "не в отчёте", brotli: "не в отчёте" },
    pros: ["Query definitions + instances + client", "Abort/cancel из коробки", "Mutations + infinite"],
  },
  {
    name: "@echojs/store",
    href: "/packages/store",
    desc: "Минимальный store layer поверх reactivity: value/set/update/reset + расширения.",
    tags: ["store", "extend", "ssr"],
    size: { min: "7.81 kB", gzip: "2.99 kB", brotli: "2.77 kB" },
    pros: ["SSR-friendly, без browser API", ".extend() для actions/debug/readonly", "subscribe + events"],
  },
  {
    name: "@echojs/persist",
    href: "/packages/persist",
    desc: "Persist слой (расширения к store) — отдельным пакетом.",
    tags: ["persist", "storage"],
    size: { min: "11.99 kB", gzip: "4.53 kB", brotli: "4.11 kB" },
    pros: ["Отделён от store (не тянет browser API)", "Расширения через extension-паттерн"],
  },
  {
    name: "@echojs/i18n",
    href: "/packages",
    desc: "i18n для приложений EchoJS (в репо есть пакет @echojs/i18n).",
    tags: ["i18n"],
    size: { min: "8.06 kB", gzip: "3.19 kB", brotli: "2.93 kB" },
    pros: ["Лёгкий слой локализации", "Подходит для model-first архитектуры"],
  },
  {
    name: "@echojs/url-state",
    href: "/packages",
    desc: "Синхронизация состояния с URL: удобно для фильтров/табов/поиска.",
    tags: ["url", "state"],
    size: { min: "16.61 kB", gzip: "5.86 kB", brotli: "5.30 kB" },
    pros: ["URL как источник правды", "Удобно для shareable state"],
  },
  {
    name: "@echojs/form",
    href: "/packages",
    desc: "Формы/валидация в model-слое (см. пакет @echojs/form).",
    tags: ["forms", "validation"],
    size: { min: "17.77 kB", gzip: "6.12 kB", brotli: "5.56 kB" },
    pros: ["Model-first формы", "Подходит под signals/store"],
  },
];
---

<BaseLayout
  title="Документация"
  description="EchoJS: документация по пакетам, философии и быстрым гайдам."
>
  <section class="hero">
    <div class="container heroGrid">
      <div>
        <div class="pill">
          <span class="mono">apps/docs</span>
          <span>·</span>
          <span>Astro</span>
          <span>·</span>
          <span>в стиле TanStack</span>
        </div>

        <h1 class="h1" style="margin-top: 14px;">
          Экосистема <span class="gradText">EchoJS</span> —
          <br />пакеты, которые собираются вместе
        </h1>

        <p class="lead">
          EchoJS — набор маленьких framework-agnostic пакетов: реактивность, DOM,
          UI, роутер, query/cache и поддерживающие библиотеки. Цель —
          предсказуемая модель, строгие контракты и удобная композиция.
        </p>

        <div class="ctaRow">
          <a class="btn btnPrimary" href="/getting-started">Быстрый старт</a>
          <a class="btn" href="/packages">Каталог пакетов</a>
          <a class="btn" href="/guides/philosophy">Философия</a>
        </div>
      </div>

      <div class="card">
        <div class="cardPad">
          <p class="kicker">Ключевые идеи</p>
          <div class="grid" style="gap: 10px;">
            <div class="col12" style="padding: 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: rgba(255,255,255,0.03);">
              <p class="cardTitle">Model-first API</p>
              <p class="cardText">Состояние и side effects живут в моделях, UI — опционален.</p>
            </div>
            <div class="col12" style="padding: 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: rgba(255,255,255,0.03);">
              <p class="cardTitle">Signals everywhere</p>
              <p class="cardText">Единый реактивный слой вместо фреймворк-специфичных хуков.</p>
            </div>
            <div class="col12" style="padding: 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: rgba(255,255,255,0.03);">
              <p class="cardTitle">Маленькие пакеты</p>
              <p class="cardText">Выбирай только то, что нужно: router/query/ui — не обязательны.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="kicker">Пакеты</p>
      <div class="accList" style="margin-top: 10px;">
        {packages.map((p) => (
          <details class="acc">
            <summary>
              <div class="accHeader">
                <span class="accName mono">{p.name}</span>
                <span class="accDesc">{p.desc}</span>
              </div>
              <span class="accChevron" aria-hidden="true">⌄</span>
            </summary>

            <div class="accBody">
              <div class="accCols">
                <div>
                  <p class="cardTitle">Преимущества</p>
                  <ul class="list">
                    {p.pros.map((x) => (
                      <li>{x}</li>
                    ))}
                  </ul>

                  <div class="pkgMeta">
                    {p.tags.map((t) => (
                      <span class="badge mono">{t}</span>
                    ))}
                  </div>
                </div>

                <div>
                  <p class="cardTitle">Размер (bundle)</p>
                  <p class="cardText">
                    <span class="mono">min</span>: {p.size.min}<br />
                    <span class="mono">gzip</span>: {p.size.gzip}<br />
                    <span class="mono">brotli</span>: {p.size.brotli}
                  </p>

                  <div class="pkgMeta">
                    <a class="btn btnPrimary" href={p.href}>Открыть</a>
                  </div>
                </div>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
