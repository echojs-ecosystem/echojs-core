---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Быстрый старт" description="Как начать использовать пакеты EchoJS в монорепо.">
  <section class="section">
    <div class="container">
      <p class="kicker">Быстрый старт</p>

      <div class="card">
        <div class="cardPad">
          <p class="cardTitle">Монорепо (workspace)</p>
          <p class="cardText">
            Внутри этого репозитория пакеты подключаются через <span class="mono">workspace:*</span>.
            Сборка/тесты идут через <span class="mono">turbo</span>, пакет-менеджер — <span class="mono">bun</span>.
          </p>

          <div class="grid" style="margin-top: 14px;">
            <div class="col6">
              <p class="cardTitle">Команды</p>
              <p class="cardText mono" style="white-space: pre-wrap;">
bun run dev
bun run test
bun run build
              </p>
            </div>
            <div class="col6">
              <p class="cardTitle">Дальше</p>
              <p class="cardText">
                Начни с <a href="/packages/reactivity"><span class="mono">@echojs/reactivity</span></a>,
                затем посмотри <a href="/packages/router"><span class="mono">@echojs/router</span></a> и
                <a href="/packages/query"><span class="mono">@echojs/query</span></a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

