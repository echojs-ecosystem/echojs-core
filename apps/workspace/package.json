{
  "name": "@echojs-ecosystem/workspace",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:server & bun run dev:client",
    "dev:client": "bun run --cwd client dev",
    "dev:server": "cd server && go run .",
    "build": "bun run --cwd client build",
    "build:server": "cd server && go build -o workspace-server .",
    "typecheck": "bun run --cwd shared typecheck && bun run --cwd client typecheck",
    "lint": "bun run --cwd client lint"
  }
}
