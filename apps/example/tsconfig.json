{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@pages/*": ["src/pages/*"],
      "@entities/*": ["src/entities/*"],
      "@features/*": ["src/features/*"],
      "@widgets/*": ["src/widgets/*"],
      "@shared/*": ["src/shared/*"],
      "@echojs/reactivity": ["../../packages/reactivity/src/index.ts"],
      "@echojs/form": ["../../packages/form/src/index.ts"],
      "@echojs/form/*": ["../../packages/form/src/*"],
      "@echojs/hyperdom": ["../../packages/hyperdom/src/index.ts"],
      "@echojs/hyperdom/*": ["../../packages/hyperdom/src/*"],
      "@echojs/router": ["../../packages/router/src/index.ts"],
      "@echojs/router/hyperdom": ["../../packages/router/src/hyperdom/index.ts"],
      "@echojs/store": ["../../packages/store/src/index.ts"],
      "@echojs/persist": ["../../packages/persist/src/index.ts"],
      "@echojs/url-state": ["../../packages/url-state/src/index.ts"],
      "@echojs/query": ["../../packages/query/src/index.ts"],
      "@echojs/i18n": ["../../packages/i18n/src/index.ts"],
      "@echojs/framework": ["../../packages/framework/src/index.ts"],
      "@echojs/framework/app": ["../../packages/framework/src/app/index.ts"],
      "@echojs/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": ["src", "public/locales/*.json"]
}
