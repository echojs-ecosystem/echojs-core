{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@echojs-ecosystem/core",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@echojs-ecosystem/core": ["../../packages/core/src/index.ts"],
      "@echojs-ecosystem/core/*": ["../../packages/core/src/*"],
      "@echojs-ecosystem/reactivity": ["../../packages/reactivity/src/index.ts"]
    }
  },
  "include": ["src"]
}
