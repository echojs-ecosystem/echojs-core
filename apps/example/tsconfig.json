{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@echojs-ecosystem/reactivity": ["../../packages/reactivity/src/index.ts"],
      "@echojs/form": ["../../packages/form/src/index.ts"],
      "@echojs/form/*": ["../../packages/form/src/*"],
      "@echojs/hyperdom": ["../../packages/hyperdom/src/index.ts"],
      "@echojs/hyperdom/*": ["../../packages/hyperdom/src/*"]
    }
  },
  "include": ["src"]
}
